# FastAPI MCP bridge environment
# Copy this file to server/mcp_server/.env and fill in your own values.

# Required: OpenRouter API key used by the FastAPI bridge.
OPENROUTER_API_KEY=

# Optional logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: override if Spring Boot is not reachable at localhost:8000
SPRING_BOOT_BASE_URL=http://localhost:8000
