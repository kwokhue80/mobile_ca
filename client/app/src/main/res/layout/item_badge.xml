<?xml version="1.0" encoding="utf-8"?>
<!-- Author: HuaYuan Xie -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivBadgeIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/badges_icon" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvBadgeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Marathoner"
        android:textColor="#1F1F1F"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvBadgeDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center|top"
        android:maxLines="3"
        android:minLines="3"
        android:ellipsize="end"
        android:text="Walk or run a total of 1,000 km"
        android:textColor="#7A7A7A"
        android:textSize="11sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Collect"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        app:backgroundTint="#D9D9D9"
        app:cornerRadius="16dp" />

</LinearLayout>
