<?xml version="1.0" encoding="utf-8"?>
<!-- Author: HuaYuan Xie -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/dragHandle"
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        android:id="@+id/tvAddManuallyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Add wellness record"
        android:textColor="#1F1F1F"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFood"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Food"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/food_summary_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSleep"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Sleep"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/sleep_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddHydration"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Hydration"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/hydration_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddWeight"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Weight"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/weight_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddExercise"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Exercise"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/exercise_days_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddMood"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Mood"
            android:textAllCaps="false"
            android:textColor="#1F1F1F"
            android:textSize="14sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="9sp"
            android:autoSizeMaxTextSize="14sp"
            android:autoSizeStepGranularity="1sp"
            app:backgroundTint="#C7D0CF"
            app:cornerRadius="24dp"
            app:icon="@drawable/mental_health_icon"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#1F1F1F" />

    </LinearLayout>

</LinearLayout>
