<?xml version="1.0" encoding="utf-8"?>
<!-- Author: HuaYuan Xie -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnHistory">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Zone A: card carousel -->
        <LinearLayout
            android:id="@+id/zoneA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#EEF1F5">

<!--            <TextView-->
<!--                android:id="@+id/tvDashboardTitle"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:layout_marginTop="45dp"-->
<!--                android:fontFamily="@font/bebas_neue"-->
<!--                android:text="Nova Health"-->
<!--                android:textColor="#1F1F1F"-->
<!--                android:textSize="30sp"-->
<!--                android:textStyle="bold" />-->

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerDashboard"
                android:layout_width="match_parent"
                android:layout_height="265dp" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabDots"
                android:layout_width="56dp"
                android:layout_height="24dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/dot_indicator_selector"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMinWidth="0dp"
                app:tabPaddingStart="0dp"
                app:tabPaddingEnd="0dp"
                app:tabRippleColor="@android:color/transparent" />

        </LinearLayout>

        <!-- Zone B: activity feed (white background extends behind Add Activity / Set Goals) -->
        <LinearLayout
            android:id="@+id/zoneB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_top_rounded_white"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddActivity"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="+ Add Activity"
                    android:textSize="13sp"
                    android:textColor="#1F1F1F"
                    app:strokeColor="#1F1F1F" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetGoals"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="Set Goals"
                    android:textSize="13sp"
                    android:textColor="#1F1F1F"
                    app:strokeColor="#1F1F1F" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvActivityTrackedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="6dp"
                android:text="Activity Tracked"
                android:textColor="#1F1F1F"
                android:textSize="20sp"
                android:textStyle="bold" />

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerActivityRecords"
                android:layout_width="match_parent"
                android:layout_height="288dp"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHistory"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="2dp"
        android:text="History"
        android:textColor="#1F1F1F"
        app:strokeColor="#1F1F1F"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
