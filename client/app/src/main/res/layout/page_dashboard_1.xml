    <!-- Hydration 卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHydration"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:clickable="true"
        android:focusable="true"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardCalBurned"
        app:layout_constraintStart_toStartOf="@id/cardCalBurned"
        app:layout_constraintEnd_toEndOf="@id/cardCalBurned"
        android:layout_marginTop="15dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 填色进度条，撑满卡片背景 -->
            <ProgressBar
                android:id="@+id/progressHydration"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="1500"
                android:progress="1250"
                android:progressBackgroundTint="#52ADFF"
                android:progressTint="#83B8C0F0" />

            <!-- 图标+文字层，浮在进度条上方 -->
