                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.3" />

                <!-- 图标 -->
                <ImageView
                    android:id="@+id/iconCalBurned"
                    android:layout_width="45dp"
                    android:layout_height="60dp"
                    android:src="@drawable/calories_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="10dp" />

                <!-- 文字组，左边贴住40%参考线 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="@id/guideline40CalBurned"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:text="Calories"
                        android:textColor="#37423F"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCalBurned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:text="203Cal"
                        android:textSize="26sp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sleep 卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSleep"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:clickable="true"
        android:focusable="true"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardSteps"
        app:layout_constraintStart_toStartOf="@id/cardSteps"
        app:layout_constraintEnd_toEndOf="@id/cardSteps"
        android:layout_marginTop="15dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

