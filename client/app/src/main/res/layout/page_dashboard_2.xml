<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Exercise days 卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardExerciseDays"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:clickable="true"
        android:focusable="true"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cardEmpty1"
        android:layout_marginTop="30dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="9dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 填色进度条，撑满卡片背景 -->
            <ProgressBar
                android:id="@+id/progressExerciseDays"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="5"
                android:progress="2"
                android:progressBackgroundTint="#A6E2DD"
                android:progressTint="#8327837B" />

            <!-- 图标+文字层，浮在进度条上方 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 40%位置参考线 -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline40ExerciseDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.3" />

                <!-- 图标 -->
                <ImageView
                    android:id="@+id/iconExerciseDays"
                    android:layout_width="45dp"
                    android:layout_height="50dp"
                    android:src="@drawable/exercise_days_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="10dp" />

                <!-- 文字组，左边贴住40%参考线 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="@id/guideline40ExerciseDays"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:text="Exercise Days"
                        android:textColor="#37423F"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvExerciseDays"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:text="2 of 5"
                        android:textSize="24sp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Mental Health 卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMentalHealth"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:clickable="true"
        android:focusable="true"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardExerciseDays"
        app:layout_constraintStart_toStartOf="@id/cardExerciseDays"
        app:layout_constraintEnd_toEndOf="@id/cardExerciseDays"
        android:layout_marginTop="15dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 纯背景色 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#A6E2DD" />

            <!-- 图标+文字层，浮在进度条上方 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 40%位置参考线 -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline40MentalHealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.3" />

                <!-- 图标 -->
                <ImageView
                    android:id="@+id/iconMentalHealth"
                    android:layout_width="45dp"
                    android:layout_height="50dp"
                    android:src="@drawable/mental_health_icon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="10dp" />

                <!-- 文字组，左边贴住40%参考线 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="@id/guideline40MentalHealth"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:text="Mental Health"
                        android:textColor="#37423F"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMentalHealth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:textStyle="bold"
                        android:text="Good"
                        android:textSize="26sp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 右侧空白卡片 1 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmpty1"
        android:layout_width="0dp"
        android:layout_height="58dp"
        app:cardBackgroundColor="#E0E0E0"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/cardExerciseDays"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"
        android:layout_marginStart="9dp"
        android:layout_marginEnd="20dp" />

    <!-- 右侧空白卡片 2 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmpty2"
        android:layout_width="0dp"
        android:layout_height="58dp"
        app:cardBackgroundColor="#E0E0E0"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardEmpty1"
        app:layout_constraintStart_toStartOf="@id/cardEmpty1"
        app:layout_constraintEnd_toEndOf="@id/cardEmpty1"
        android:layout_marginTop="15dp" />

    <!-- 左侧空白卡片 4 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmpty4"
        android:layout_width="0dp"
        android:layout_height="58dp"
        app:cardBackgroundColor="#E0E0E0"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardMentalHealth"
        app:layout_constraintStart_toStartOf="@id/cardMentalHealth"
        app:layout_constraintEnd_toEndOf="@id/cardMentalHealth"
        android:layout_marginTop="15dp" />

    <!-- 右侧空白卡片 3 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEmpty3"
        android:layout_width="0dp"
        android:layout_height="58dp"
        app:cardBackgroundColor="#E0E0E0"
        app:strokeWidth="0dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/cardEmpty2"
        app:layout_constraintStart_toStartOf="@id/cardEmpty2"
        app:layout_constraintEnd_toEndOf="@id/cardEmpty2"
        android:layout_marginTop="15dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
