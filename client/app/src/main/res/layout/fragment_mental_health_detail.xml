<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Toolbar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Mental Health"
                android:textColor="#1F1F1F"
                android:textSize="18sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Time range tabs: Day / Week / Month only -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabDay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="D"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0B57D0"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabWeek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="W"
                android:textColor="#1F1F1F"
                app:backgroundTint="#EEF1F5"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="M"
                android:textColor="#1F1F1F"
                app:backgroundTint="#EEF1F5"
                app:cornerRadius="20dp" />

        </LinearLayout>

        <!-- Period navigator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPeriodLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today"
                android:textColor="#1F1F1F"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnPrevPeriod"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_circle_button"
                android:contentDescription="Previous"
                android:src="@drawable/ic_chevron_left" />

            <ImageButton
                android:id="@+id/btnNextPeriod"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_circle_button"
                android:contentDescription="Next"
                android:src="@drawable/ic_chevron_right" />

            <ImageButton
                android:id="@+id/btnPickDate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_button"
                android:contentDescription="Pick date"
                android:src="@drawable/ic_calendar" />

        </LinearLayout>

        <!-- Day-only: a single mood icon + word, no chart/axis -->
        <LinearLayout
            android:id="@+id/layoutDayMood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvDayMoodEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🙂"
                android:textSize="96sp" />

            <TextView
                android:id="@+id/tvDayMoodWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Good"
                android:textColor="#1F1F1F"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDayMoodValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="7.2/10"
                android:textColor="#7A7A7A"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Week/Month: mood chart, fixed 1-10 scale, x-axis is time -->
        <FrameLayout
            android:id="@+id/chartMoodContainer"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartMood"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- Week/Month: 3 mood-icon checkpoints (early / mid / late) below the chart -->
        <LinearLayout
            android:id="@+id/layoutMoodNodes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/nodeMood1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNodeMood1Emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🙂"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/tvNodeMood1Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mo–Tu"
                    android:textColor="#7A7A7A"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/nodeMood2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNodeMood2Emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🙂"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/tvNodeMood2Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="We–Th"
                    android:textColor="#7A7A7A"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/nodeMood3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNodeMood3Emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🙂"
                    android:textSize="40sp" />

                <TextView
                    android:id="@+id/tvNodeMood3Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Fr"
                    android:textColor="#7A7A7A"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Mood summary, styled like a speech-bubble/dialog card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#E3F5E1"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvMoodSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:lineSpacingExtra="4dp"
                android:text="Today's mood has been good overall, averaging 7.2/10."
                android:textColor="#1B4D2E"
                android:textSize="16sp" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
